# Copy this file to `.env.local` for local development:
# cp .env.example .env.local

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for `npm run db:push:url "<connection-string>"`
# Copy from Supabase Dashboard → Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
TURNIX_SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
CRON_SECRET=replace-with-cron-secret

# OAuth — Google Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — OneDrive
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=common

# OAuth — Dropbox
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# OAuth — Yandex
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
